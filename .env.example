# ShipWith.AI Environment Configuration

# Mode: 'cli' for local Claude CLI, 'api' for Anthropic API
SHIPWITHAI_MODE=cli

# Anthropic API (required if SHIPWITHAI_MODE=api)
ANTHROPIC_API_KEY=sk-ant-...

# Network: 'mainnet' or 'testnet'
SHIPWITHAI_NETWORK=testnet

# RPC URLs
SHIPWITHAI_RPC_URL=https://sepolia.base.org
ETH_RPC_URL=https://eth.drpc.org

# Base URL for deployed app (used in ERC-8004 registration)
SHIPWITHAI_BASE_URL=http://localhost:3000

# ERC-8004 Registration (requires ETH on mainnet for gas)
REGISTRATION_PRIVATE_KEY=0x...

# Agent Wallets (Base Sepolia - for x402 payments)
# Generate with: node -e "console.log(require('viem/accounts').generatePrivateKey())"
AGENT_WALLET_PM=0x...
AGENT_WALLET_UX_ANALYST=0x...
AGENT_WALLET_UI_DESIGNER=0x...
AGENT_WALLET_UI_DEVELOPER=0x...
AGENT_WALLET_BACKEND_DEVELOPER=0x...
AGENT_WALLET_SOLIDITY_DEVELOPER=0x...
AGENT_WALLET_SOLIDITY_AUDITOR=0x...
AGENT_WALLET_INFRASTRUCTURE=0x...
AGENT_WALLET_QA_TESTER=0x...
AGENT_WALLET_UNIT_TESTER=0x...
AGENT_WALLET_TECH_WRITER=0x...
AGENT_WALLET_MARKETING=0x...

# User wallet for triggering projects
USER_WALLET_PRIVATE_KEY=0x...
